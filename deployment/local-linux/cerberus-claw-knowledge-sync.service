[Unit]
Description=Refresh official Claw Royale canonical knowledge
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory=/opt/cerberus-current
ExecStart=/opt/cerberus-venv/bin/python /opt/cerberus-current/src/claw_knowledge_sync.py --output /var/data/.cerberus/claw_royale_canonical_snapshot.md
NoNewPrivileges=true
PrivateTmp=true
