#!/usr/bin/env bash
set -Eeuo pipefail

SCRIPT_DIR="$(
    cd -- "$(dirname -- "${BASH_SOURCE[0]}")"
    pwd
)"

usage() {
    cat <<'EOF'
CERBERUS local deployment controller

Usage:
  cerberusctl status
  cerberusctl build <full-commit-hash>
  cerberusctl verify <full-commit-hash>
  cerberusctl stage <full-commit-hash>
  cerberusctl promote <full-commit-hash>
  cerberusctl rollback
  cerberusctl history
  cerberusctl help

Commands:
  status     Show production, staging, rollback, services, ports, and releases.
  build      Build an immutable release from a Git commit.
  verify     Compile and test an immutable release.
  stage      Activate an immutable release in staging.
  promote    Promote the staged release to production.
  rollback   Roll production back to the recorded previous release.
  history    Show immutable releases, verification state, and lane assignment.
  help       Show this help message.
EOF
}

require_commit() {
    if [ "$#" -ne 1 ]; then
        echo "A full 40-character commit hash is required."
        echo
        usage
        exit 64
    fi
}

COMMAND="${1:-help}"

case "$COMMAND" in
    status)
        if [ "$#" -ne 1 ]; then
            usage
            exit 64
        fi

        exec "$SCRIPT_DIR/status.sh"
        ;;

    build)
        shift
        require_commit "$@"
        exec "$SCRIPT_DIR/build-release.sh" "$1"
        ;;

    verify)
        shift
        require_commit "$@"
        exec "$SCRIPT_DIR/verify-release.sh" "$1"
        ;;

    stage)
        shift
        require_commit "$@"
        exec "$SCRIPT_DIR/activate-staging.sh" "$1"
        ;;

    promote)
        shift
        require_commit "$@"
        exec "$SCRIPT_DIR/promote-production.sh" "$1"
        ;;

    rollback)
        if [ "$#" -ne 1 ]; then
            usage
            exit 64
        fi

        exec "$SCRIPT_DIR/rollback-production.sh"
        ;;

    history)
        if [ "$#" -ne 1 ]; then
            usage
            exit 64
        fi

        exec "$SCRIPT_DIR/history.sh"
        ;;

    help|-h|--help)
        usage
        ;;

    *)
        echo "Unknown command: $COMMAND"
        echo
        usage
        exit 64
        ;;
esac
